{
  "name": "decision-pathfinder",
  "version": "1.0.0",
  "description": "A modular decision tree engine for LLM-driven workflows — build, execute, and analyze decision paths with Gemini Flash Lite",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "decision-pathfinder-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "demo": "tsx scripts/demo-readme-generator.ts",
    "benchmark": "tsx scripts/benchmark.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "decision-tree",
    "pathfinder",
    "llm",
    "gemini",
    "ai-agent",
    "tree-executor",
    "mcp",
    "mcp-server"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@google/generative-ai": "^0.24.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
