{
  "name": "decision-pathfinder",
  "version": "1.0.0",
  "description": "A modular decision tree engine for LLM-driven workflows — build, execute, and analyze decision paths with Gemini Flash Lite",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "demo": "tsx scripts/demo-readme-generator.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "decision-tree",
    "pathfinder",
    "llm",
    "gemini",
    "ai-agent",
    "tree-executor"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@google/generative-ai": "^0.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
